# Mock mode is the default (MSW intercepts same-origin /api calls).
#
# To run against the real backend instead, use `npm run dev:api` (which loads .env.integration):
#   VITE_USE_MSW=false           # turn the mock worker off
#   VITE_PROXY_TARGET=http://localhost:8080   # the dev server proxies /api here (no CORS)
#
# VITE_API_URL only needs setting for a direct (non-proxied) absolute backend origin, which
# then requires the backend to send CORS headers. Leave empty for the proxy/mock setup.
# VITE_API_URL=
